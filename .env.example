SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key-here

# Required only for npm run db:setup (create table)
# Supabase Dashboard → Project Settings → Database → Connection string (URI, Session pooler)
SUPABASE_DB_URL=postgresql://postgres.your-project-id:YOUR_DB_PASSWORD@aws-0-region.pooler.supabase.com:5432/postgres
